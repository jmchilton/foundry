---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const all = await getCollection('content');
const pipelines = all
  .filter(n => n.data.type === 'pipeline' && n.data.status !== 'archived')
  .sort((a, b) => (a.data as any).title.localeCompare((b.data as any).title));
const totalPhases = pipelines.reduce((sum, p) => sum + phaseCount((p.data as any).phases), 0);

function phaseCount(phases: unknown): number {
  return Array.isArray(phases) ? phases.length : 0;
}
---
<Base title="Pipelines">
  <section class="page-hero bg-grain" aria-labelledby="pipelines-heading">
    <span class="eyebrow mb-3">Harness Pipelines</span>
    <div class="page-hero-grid">
      <div>
        <h1 id="pipelines-heading" class="page-title text-balance">Ordered Mold sequences.</h1>
        <p class="page-lede text-pretty">
          Pipelines compose Molds into harness journeys and make the Foundry navigable from source to target.
        </p>
      </div>
      <dl class="page-stats" aria-label="Pipeline stats">
        <div>
          <dt>Total</dt>
          <dd>{pipelines.length}</dd>
        </div>
        <div>
          <dt>Phases</dt>
          <dd>{totalPhases}</dd>
        </div>
      </dl>
    </div>
  </section>

  <table class="data-table">
    <thead><tr><th>Pipeline</th><th>Summary</th><th>Phases</th><th>Status</th></tr></thead>
    <tbody>
      {pipelines.map(p => {
        const d = p.data as any;
        return (
          <tr>
            <td><a href={`${base}/${p.id}/`}>{d.title}</a></td>
            <td class="text-sm text-(--color-text-muted)">{d.summary}</td>
            <td>{phaseCount(d.phases)}</td>
            <td><span class={`badge badge-${d.status}`}>{d.status}</span></td>
          </tr>
        );
      })}
    </tbody>
  </table>
</Base>
