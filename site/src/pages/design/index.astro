---
import Base from '../../layouts/Base.astro';
import { DESIGN_DOCS } from '../../lib/design-docs';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base
  title="Design Docs"
  description="Working design records for the Galaxy Workflow Foundry."
>
  <section class="design-hero bg-grain" aria-labelledby="design-heading">
    <span class="eyebrow mb-4">Design Record</span>
    <h1 id="design-heading">The working record behind the Foundry story.</h1>
    <p>
      Start with the story, then come here for the deeper rationale: the principles, architecture,
      Mold inventory, casting procedure, corpus approach, and pipeline narrative that shape the
      public Foundry pages.
    </p>
  </section>

  <div class="design-doc-grid">
    {DESIGN_DOCS.map((doc, index) => (
      <a href={`${base}/design/${doc.slug}/`} class="design-doc-card tinted-shadow tinted-shadow-hover">
        <span class="design-doc-num font-mono">{String(index + 1).padStart(2, '0')}</span>
        <span class="design-doc-title">{doc.title}</span>
        <span class="design-doc-summary">{doc.summary}</span>
        <span class="design-doc-source font-mono">READ THE RECORD</span>
      </a>
    ))}
  </div>
</Base>

<style>
  .design-hero {
    padding: 1.5rem 0 1.25rem;
    max-width: 58rem;
  }
  .design-hero h1 {
    margin: 0 0 1rem;
    color: var(--color-galaxy-dark);
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.04;
    letter-spacing: -0.025em;
    text-wrap: balance;
  }
  .dark .design-hero h1 {
    color: var(--color-text-primary);
  }
  .design-hero p {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: 1.05rem;
    line-height: 1.72;
    text-wrap: pretty;
  }
  .design-hero code {
    font-family: var(--font-mono);
    background: var(--color-surface-hover);
    border-radius: 0.25rem;
    padding: 0.08rem 0.28rem;
  }
  .design-doc-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.85rem;
    margin-top: 1.25rem;
  }
  .design-doc-card {
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    gap: 0.55rem;
    min-height: 13rem;
    padding: 1rem;
    color: inherit;
    text-decoration: none;
    border: 1px solid var(--color-border-subtle);
    border-radius: 0.5rem;
    background: var(--color-surface-raised);
    transition: border-color 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
  }
  .design-doc-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }
  .design-doc-num {
    color: var(--color-accent);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
  }
  .design-doc-title {
    color: var(--color-text-primary);
    font-weight: 700;
    font-size: 1.18rem;
    line-height: 1.18;
  }
  .design-doc-summary {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.55;
    text-wrap: pretty;
  }
  .design-doc-source {
    color: var(--color-text-muted);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
  }
  @media (max-width: 900px) {
    .design-doc-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 560px) {
    .design-doc-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
