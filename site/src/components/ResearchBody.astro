---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'content'>;
}

const { entry } = Astro.props;
const data = entry.data as any;
---
<div class="mb-6 flex flex-wrap gap-2 items-center">
  <span class="text-xs px-2 py-1 rounded bg-(--color-galaxy-grey) text-white font-mono">{data.subtype}</span>
  {data.component && <span class="text-xs px-2 py-1 rounded border border-(--color-border) font-mono">{data.component}</span>}
</div>
