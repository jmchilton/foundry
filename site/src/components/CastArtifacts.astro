---
import { listCastsForMold, type CastArtifact } from '../lib/casts';

interface Props {
  moldSlug: string;
}

const { moldSlug } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const casts: CastArtifact[] = listCastsForMold(moldSlug);

const TARGET_LABEL: Record<string, string> = {
  claude: 'Claude skill',
  web: 'Web skill',
  generic: 'Generic skill',
};
---
{casts.length > 0 && (
  <section class="mb-6 p-3 rounded-lg border border-(--color-border)">
    <h3 class="text-sm font-semibold mb-2">Cast artifacts</h3>
    <ul class="list-none p-0 space-y-1 text-sm">
      {casts.map(c => (
        <li class="flex flex-wrap items-baseline gap-2">
          <span class="text-xs px-2 py-0.5 rounded bg-(--color-surface-raised) font-mono">{TARGET_LABEL[c.target] ?? c.target}</span>
          {c.target === 'claude' && c.hasSkill ? (
            <a href={`${base}/usage/claude/${c.moldSlug}/`} class="text-(--color-link) hover:underline font-mono">{c.moldSlug}</a>
          ) : (
            <span class="font-mono">{c.moldSlug}</span>
          )}
          {c.description && <span class="text-(--color-text-secondary)">— {c.description}</span>}
        </li>
      ))}
    </ul>
    <p class="text-xs text-(--color-text-secondary) mt-2">
      <a href={`${base}/usage/`} class="text-(--color-link) hover:underline">How to install →</a>
    </p>
  </section>
)}
