---
import type { CollectionEntry } from 'astro:content';
import { resolveWikiLink, type WikiLinkTarget } from '../lib/wiki-links';
import ReferenceContract from './ReferenceContract.astro';

interface Props {
  entry: CollectionEntry<'content'>;
  linkMap: Map<string, WikiLinkTarget>;
}

const { entry, linkMap } = Astro.props;
const data = entry.data as any;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function resolveAll(arr: string[] | undefined) {
  if (!arr) return [];
  return arr.map(wl => resolveWikiLink(wl, linkMap, base));
}

const patterns = resolveAll(data.patterns);
const cliCommands = resolveAll(data.cli_commands);
const prompts = resolveAll(data.prompts);

const axisChip = data.axis;
const specifier = data.source ?? data.target ?? data.tool ?? null;
---
<div class="mb-6 flex flex-wrap gap-2 items-center">
  <span class="text-xs px-2 py-1 rounded bg-(--color-galaxy-primary) text-white font-mono">{axisChip}</span>
  {specifier && <span class="text-xs px-2 py-1 rounded border border-(--color-border) font-mono">{specifier}</span>}
  <span class="text-xs text-(--color-text-secondary) font-mono">{data.name}</span>
</div>

<ReferenceContract references={data.references} linkMap={linkMap} />

{(patterns.length + cliCommands.length + prompts.length) > 0 && (
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-6">
    {patterns.length > 0 && (
      <section class="p-3 rounded-lg border border-(--color-border)">
        <h3 class="text-sm font-semibold mb-2">Patterns</h3>
        <ul class="list-none p-0 space-y-1 text-sm">
          {patterns.map(l => (
            <li>
              {l.href
                ? <a href={l.href} title={l.summary || undefined} class="text-(--color-link) hover:underline">{l.label}</a>
                : <span class="dangling">{l.label}</span>}
            </li>
          ))}
        </ul>
      </section>
    )}
    {cliCommands.length > 0 && (
      <section class="p-3 rounded-lg border border-(--color-border)">
        <h3 class="text-sm font-semibold mb-2">CLI Commands</h3>
        <ul class="list-none p-0 space-y-1 text-sm font-mono">
          {cliCommands.map(l => (
            <li>
              {l.href
                ? <a href={l.href} title={l.summary || undefined} class="text-(--color-link) hover:underline">{l.label}</a>
                : <span class="dangling">{l.label}</span>}
            </li>
          ))}
        </ul>
      </section>
    )}
    {prompts.length > 0 && (
      <section class="p-3 rounded-lg border border-(--color-border)">
        <h3 class="text-sm font-semibold mb-2">Prompts</h3>
        <ul class="list-none p-0 space-y-1 text-sm">
          {prompts.map(l => (
            <li>
              {l.href
                ? <a href={l.href} title={l.summary || undefined} class="text-(--color-link) hover:underline">{l.label}</a>
                : <span class="dangling">{l.label}</span>}
            </li>
          ))}
        </ul>
      </section>
    )}
  </div>
)}

{(data.input_schemas || data.output_schemas || data.examples) && (
  <dl class="meta mb-6 p-3 rounded-lg bg-(--color-surface-raised) text-sm">
    {data.input_schemas && data.input_schemas.length > 0 && (
      <>
        <dt>Input schemas:</dt>
        <dd>{data.input_schemas.join(', ')}</dd>
      </>
    )}
    {data.output_schemas && data.output_schemas.length > 0 && (
      <>
        <dt>Output schemas:</dt>
        <dd>{data.output_schemas.join(', ')}</dd>
      </>
    )}
    {data.examples && data.examples.length > 0 && (
      <>
        <dt>Examples:</dt>
        <dd>{data.examples.join(', ')}</dd>
      </>
    )}
  </dl>
)}
