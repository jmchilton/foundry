{
  "name": "foundry",
  "version": "0.0.0",
  "private": true,
  "description": "Galaxy Workflow Foundry — knowledge base + casting pipeline for Galaxy workflows.",
  "type": "module",
  "scripts": {
    "validate": "tsx scripts/validate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dashboard": "tsx scripts/generate-dashboard.ts",
    "check:dashboard": "tsx scripts/generate-dashboard.ts --check",
    "index": "tsx scripts/generate-index.ts",
    "check:index": "tsx scripts/generate-index.ts --check",
    "iwc-overview": "tsx scripts/generate-iwc-overview.ts",
    "check:iwc-overview": "tsx scripts/generate-iwc-overview.ts --check",
    "cast": "tsx scripts/cast-mold.ts",
    "site:dev": "cd site && astro dev",
    "site:build": "cd site && astro build",
    "site:preview": "cd site && astro preview"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
