{
  "name": "@galaxy-foundry/tests-format-schema",
  "version": "0.0.0",
  "description": "JSON Schema and validator CLI for Galaxy workflow test files.",
  "type": "module",
  "bin": {
    "validate-tests-format": "dist/bin/validate-tests-format.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema.json": "./dist/tests.schema.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmchilton/foundry.git",
    "directory": "packages/tests-format-schema"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "sync": "node scripts/sync-schema.mjs",
    "prebuild": "pnpm sync",
    "build": "tsc && node scripts/copy-schema-assets.mjs",
    "typecheck": "tsc --noEmit",
    "test": "tsc --noEmit && vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "galaxy",
    "foundry",
    "workflow-tests",
    "schema",
    "json-schema"
  ],
  "license": "MIT",
  "dependencies": {
    "@galaxy-tool-util/schema": "^1.1.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
